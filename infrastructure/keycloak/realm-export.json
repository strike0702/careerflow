{
  "id": "careerflow-realm",
  "realm": "careerflow-realm",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "passwordPolicy": "length(8) and notUsername",
  "roles": {
    "realm": [
      {
        "name": "CANDIDATE",
        "description": "Candidate role"
      },
      {
        "name": "ADMIN",
        "description": "Admin role"
      }
    ]
  },
  "groups": [
    {
      "name": "candidates",
      "path": "/candidates",
      "realmRoles": [
        "CANDIDATE"
      ]
    }
  ],
  "defaultGroups": [
    "/candidates"
  ],
  "clients": [
    {
      "clientId": "careerflow-api-gateway",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:8080/*",
        "https://oauth.pstmn.io/v1/callback",
        "http://localhost:9000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    }
  ],
  "users": [
    {
      "username": "candidate@careerflow.com",
      "email": "candidate@careerflow.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "John",
      "lastName": "Candidate",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "CANDIDATE"
      ]
    },
    {
      "username": "admin@careerflow.com",
      "email": "admin@careerflow.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Jane",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    }
  ]
}
