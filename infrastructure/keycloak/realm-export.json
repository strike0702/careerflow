{
  "id": "careerflow-realm",
  "realm": "careerflow-realm",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "CANDIDATE",
        "description": "Candidate role"
      },
      {
        "name": "ADMIN",
        "description": "Admin role"
      }
    ]
  },
  "clients": [
    {
      "clientId": "careerflow-api-gateway",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:8080/*",
        "https://oauth.pstmn.io/v1/callback",
        "http://localhost:9000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true
    }
  ],
  "users": [
    {
      "username": "candidate@careerflow.com",
      "email": "candidate@careerflow.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "John",
      "lastName": "Candidate",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "CANDIDATE"
      ]
    },
    {
      "username": "admin@careerflow.com",
      "email": "admin@careerflow.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Jane",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    }
  ]
}
